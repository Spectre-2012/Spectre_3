function renderShop(tab) {
    const grid = document.getElementById('shopGrid');
    if(!grid) return;
    grid.innerHTML = "";
    
    let items, owned, current;
    if(tab === 'skins') { items = SKINS; owned = userData.unlockedSkins; current = userData.currentSkin; }
    else if(tab === 'trails') { items = TRAILS; owned = userData.unlockedTrails; current = userData.currentTrail; }
    else if(tab === 'skills') { items = SKILLS; owned = userData.unlockedSkills; current = null; } 

    items.forEach(item => {
        const isOwned = owned.includes(item.id);
        let isEquipped = false;
        let equipLabel = "";

        if(tab === 'skins' || tab === 'trails') {
            isEquipped = (current === item.id);
            if(isEquipped) equipLabel = '<div class="skin-owned" style="color:#cc00ff;">EQUIPADO</div>';
        } else {
            if(userData.equippedSkills[0] === item.id) { isEquipped = true; equipLabel = '<div class="skin-owned" style="color:#cc00ff;">EQUIPADO SLOT 1</div>'; }
            else if(userData.equippedSkills[1] === item.id) { isEquipped = true; equipLabel = '<div class="skin-owned" style="color:#ffaa00;">EQUIPADO SLOT 2</div>'; }
        }
        
        const card = document.createElement('div');
        card.className = `skin-card ${isEquipped ? 'skin-equipped' : ''}`;
        card.onclick = () => buyOrEquip(tab, item.id, item.cost);
        
        let preview = "";
        if(tab === 'skins') {
            const color = item.color === 'rainbow' ? 'linear-gradient(45deg, red, orange, yellow, green, blue, indigo, violet)' : item.color;
            preview = `<div class="skin-preview" style="background:${color}; box-shadow:0 0 15px ${item.color !== 'rainbow' ? item.color : 'white'}; border: 2px solid white;"></div>`;
        } else if (tab === 'trails') {
             const color = item.color === 'match' ? '#ffffff' : (item.color === 'rainbow' ? 'linear-gradient(90deg, #ff0000, #00ff00, #0000ff)' : item.color);
             preview = `<div class="skin-preview" style="background:#000; display:flex; align-items:center; justify-content:center; color:${color}">✨</div>`;
        } else if (tab === 'skills') {
             preview = `<div class="skin-preview" style="background:${item.style}; font-size:24px;">${item.icon}</div>`;
        }

        card.innerHTML = `
            ${preview}
            <div style="font-weight:bold; font-size:13px; color:white; margin-bottom:5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${item.name}</div>
            ${tab === 'skills' ? `<div style="font-size:10px; color:#aaa; margin-bottom:5px;">${item.desc}</div>` : ''}
            ${isEquipped ? equipLabel : (isOwned ? '<div class="skin-owned">TIENES</div>' : `<div class="skin-price">${item.cost.toLocaleString()} 💎</div>`)}
        `;
        grid.appendChild(card);
    });
}

function buyOrEquip(tab, id, cost) {
    let owned;
    if(tab === 'skins') owned = userData.unlockedSkins;
    else if(tab === 'trails') owned = userData.unlockedTrails;
    else owned = userData.unlockedSkills;
    
    if (owned.includes(id)) {
        if(tab === 'skins') userData.currentSkin = id;
        else if(tab === 'trails') userData.currentTrail = id;
        else {
            userData.equippedSkills[currentEditingSkillSlot] = id;
        }
        saveUserData();
        renderShop(tab);
    } else {
        if (userData.gems >= cost) {
            userData.gems -= cost;
            if(tab === 'skins') userData.unlockedSkins.push(id);
            else if(tab === 'trails') userData.unlockedTrails.push(id);
            else userData.unlockedSkills.push(id);
            saveUserData();
            updateUI();
            renderShop(tab);
        } else {
            alert("No tienes suficientes gemas 💎");
        }
    }
}

function toggleModal(id) {
