});

// ==================== MISIONES ====================
function checkMissionReset() {
    const now = Date.now();
    if (now - userData.missionData.lastReset > 86400000) {
        userData.missionData.played = 0; userData.missionData.won = 0;
        userData.missionData.claimed = [false, false, false];
        userData.missionData.lastReset = now;
        saveUserData();
    }
}

function updateMissionProgress(type) {
    checkMissionReset();
    let changed = false;
    if (type === 'play' && userData.missionData.played < 3) { userData.missionData.played++; changed = true; }
    else if (type === 'win' && userData.missionData.won < 1) { userData.missionData.won++; changed = true; }
    if(changed) saveUserData();
}

function renderMissions() {
    checkMissionReset();
    const list = document.getElementById('missionList'); 
    list.innerHTML = "";
    const today = new Date().toDateString();

    MISSIONS.forEach((m, idx) => {
        let buttonHtml = '';
        if (m.type === 'daily') {
             if (userData.missionData.lastDailyLogin === today) {
                 buttonHtml = `<button class="btn-claimed">HOY YA ENTRASTE</button>`;
             } else {
                 buttonHtml = `<button class="btn-claim" onclick="claimMission(${idx})">RECLAMAR</button>`;
             }
        } else {
            let progress = 0;
            if (m.type === 'play') progress = userData.missionData.played;
            if (m.type === 'win') progress = userData.missionData.won;
            let isCompleted = progress >= m.target;
            let isClaimed = userData.missionData.claimed[idx];

            if (isClaimed) buttonHtml = `<button class="btn-claimed">RECLAMADO</button>`;
            else if (isCompleted) buttonHtml = `<button class="btn-claim" onclick="claimMission(${idx})">RECLAMAR</button>`;
            else buttonHtml = `<span style="color:#666; font-weight:bold;">EN PROGRESO</span>`;
        }

        const div = document.createElement('div');
        div.className = 'mission-card';
        div.innerHTML = `
            <div class="mission-info">
                <div style="font-weight:bold;">${m.desc}</div>
                <div style="color:#39ff14;">Recompensa: ${m.reward} 💎</div>
            </div>
            <div>${buttonHtml}</div>
        `;
        list.appendChild(div);
    });
}

function claimMission(idx) {
    const today = new Date().toDateString();
    if (MISSIONS[idx].type === 'daily') {
        if (userData.missionData.lastDailyLogin === today) return;
        userData.missionData.lastDailyLogin = today;
        userData.gems += MISSIONS[idx].reward;
        saveUserData(); updateUI(); renderMissions();
        alert("¡Has recibido gemas por entrar hoy!");
        return;
    }
    if (userData.missionData.claimed[idx]) return;
    userData.gems += MISSIONS[idx].reward;
    userData.missionData.claimed[idx] = true;
    saveUserData(); updateUI(); renderMissions();
}

