// ==================== AUDIO SYSTEM ====================
let audioMap = { 'menu': null, 'loading': null };
let pendingAudioBlob = null;
let currentSource = null;

function playMusic(id) {
    if(currentSource) { currentSource.pause(); currentSource = null; }
    let blobUrl = audioMap[id];
    let volume = 0.5;
    if(id.startsWith('level_')) {
        const idx = parseInt(id.split('_')[1]);
        if(allLevels[idx] && allLevels[idx].musicBlob) {
            blobUrl = allLevels[idx].musicBlob;
            if(allLevels[idx].musicVolume !== undefined) volume = allLevels[idx].musicVolume;
        }
    }
    if (!blobUrl) return;
    const audio = new Audio(blobUrl);
    audio.loop = true; audio.volume = volume;
    audio.play().catch(e => console.log("Audio play failed:", e));
    currentSource = audio;
}

function handleGlobalMusicUpload(input) {
    const file = input.files[0]; if(!file) return;
    pendingAudioBlob = URL.createObjectURL(file);
    document.getElementById('musicFileName').innerText = file.name;
    const customOpt = document.getElementById('musicOptGroupCustom'); customOpt.innerHTML = "";
    allLevels.forEach((l, i) => { const opt = document.createElement('option'); opt.value = `level_${i}`; opt.innerText = `Nivel: ${l.name}`; customOpt.appendChild(opt); });
    toggleModal('devSettingsModal'); toggleModal('musicAssignModal');
}

function confirmMusicAssignment() {
    const target = document.getElementById('musicTargetSelect').value;
    const volume = parseFloat(document.getElementById('musicVol').value);
    if(!pendingAudioBlob) return;
    if(target.startsWith('level_')) {
        const idx = parseInt(target.split('_')[1]);
        if(allLevels[idx]) { allLevels[idx].musicBlob = pendingAudioBlob; allLevels[idx].musicVolume = volume; alert(`✅ Música asignada a: ${allLevels[idx].name}`); }
    } else {
        audioMap[target] = pendingAudioBlob; alert(`✅ Música asignada a ${target}`);
        if(target === 'menu' && gameState === 'MENU') playMusic('menu');
    }
    toggleModal('musicAssignModal');
}

function handleEditorMusicUpload(input) {
