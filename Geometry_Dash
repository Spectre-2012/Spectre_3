}

function saveUserData() {
    try {
        const dataString = JSON.stringify(userData);
        if (isDevMode) {
            localStorage.setItem(STORAGE_KEY_DEV, dataString);
        } else {
            localStorage.setItem(STORAGE_KEY_USER, dataString);
        }
        // Shared Ranking logic
        let ranking = JSON.parse(localStorage.getItem(STORAGE_KEY_RANKING) || '{"Leo": 0, "Hugo": 0}');
        let key = null;
        if(currentUsername.includes("Leo")) key = "Leo";
        else if(currentUsername.includes("Hugo")) key = "Hugo";
        else if(currentUsername.includes("Pedro")) key = "Pedro";
        if(key) {
            ranking[key] = userData.totalCups;
            localStorage.setItem(STORAGE_KEY_RANKING, JSON.stringify(ranking));
        }
    } catch(e) { console.error('Error guardando datos:', e); }
}

function loadUserData() {
    try {
        const saved = localStorage.getItem(STORAGE_KEY_USER);
        if (saved) {
            const parsed = JSON.parse(saved);
            userData = { ...userData, ...parsed };
            // Ensure compatibility
            if(!userData.equippedSkills) userData.equippedSkills = [null, null];
            if(!userData.unlockedSkills) userData.unlockedSkills = [];
            if(!userData.skillKeys) userData.skillKeys = ['KeyQ', 'KeyE'];
        }
    } catch(e) { console.error('Error cargando datos:', e); }
}

function saveLevels() {
    try {
        const dataString = JSON.stringify(allLevels);
        localStorage.setItem(STORAGE_KEY_LEVELS, dataString);
        showSaveIndicator();
        updateStorageInfo();
        return true;
    } catch(e) { console.error('Error guardando niveles:', e); return false; }
}

function loadLevels() {
    try {
        const saved = localStorage.getItem(STORAGE_KEY_LEVELS);
        if (saved && saved !== 'null' && saved !== '[]') {
            allLevels = JSON.parse(saved);
        } else {
            allLevels = JSON.parse(JSON.stringify(INITIAL_BASE_LEVELS));
        }
        updateStorageInfo();
    } catch(e) {
        console.error('Error cargando niveles:', e);
        allLevels = JSON.parse(JSON.stringify(INITIAL_BASE_LEVELS));
    }
}

