// ==================== MOTOR DEL JUEGO ====================
const TILE = 65; const GRAVITY = 0.9; const JUMP_FORCE = -16; 
let SPEED = 11; const SHIP_LIFT = -0.7; const SHIP_GRAVITY = 0.35;

let gameState = 'MENU';
let currentLevelIdx = 0;
let cameraX = 0; let shake = 0; let map = []; let mapImages = []; let mapTexts = [];
let mapWidthPixels = 0; let floorLevel = 0; let winXPosition = 0; let bgOffset = 0; 
let gravityInverted = false; let levelGemsCollected = 0;

let activeSkills = [
    { active: false, timer: 0, cooldownTimer: 0, effect: null },
    { active: false, timer: 0, cooldownTimer: 0, effect: null }
];
let canDoubleJump = false;
let isAntiGravity = false;
let doubleGemValue = false;
let bounceMode = false;

const player = { x: 0, y: 0, w: 40, h: 40, dy: 0, mode: 'CUBE', rotation: 0, onGround: false, dead: false, trail: [] };
let particles = [];
let input = false; let inputPressed = false;

function jump() {
    input = true;
    if (!inputPressed) {
        inputPressed = true;
        if (gameState === 'PLAYING' && player.mode === 'CUBE') {
            let didJump = false;
            if(player.onGround || bounceMode) {
                let force = JUMP_FORCE;
                if(hasSkillEffect(5)) force *= 1.4; // Lunar
                if(hasSkillEffect(27)) force *= 1.6; // Salto Titan
                player.dy = (gravityInverted || isAntiGravity) ? -force : force;
                player.onGround = false;
                didJump = true;
            } else if (canDoubleJump) {
                let force = JUMP_FORCE;
                player.dy = (gravityInverted || isAntiGravity) ? -force : force;
                createExplosion(player.x, player.y + 40, "#00ff00", 10);
                canDoubleJump = false;
                didJump = true;
            }
        }
    }
}

function release() { input = false; inputPressed = false; }
window.addEventListener('keyup', e => { if(e.code==='Space'||e.code==='ArrowUp'||e.code==='Enter') release(); });
window.addEventListener('mousedown', jump);
window.addEventListener('mouseup', release);

// SKILL ACTIVATION
function activateSkill(slotIdx) {
    if (gameState !== 'PLAYING') return;
    const skillId = userData.equippedSkills[slotIdx];
    if (skillId === null || skillId === undefined) return;
    
    const state = activeSkills[slotIdx];
    if (state.active || state.cooldownTimer > 0) return;

    const skill = SKILLS.find(s => s.id === skillId);
    if (!skill) return;

    state.active = true;
    state.effect = skill.id;
    state.timer = skill.duration;
    state.cooldownTimer = skill.cooldown;
    
    // Immediate Effects
    if (skill.id === 0) createExplosion(player.x, player.y, "#00ffcc", 20); // Shield
    if (skill.id === 1) { player.dy = (gravityInverted || isAntiGravity) ? 30 : -30; createExplosion(player.x, player.y, "#ff0000", 30); } // Rocket Jump
    if (skill.id === 4) createExplosion(player.x, player.y, "#ff0000", 30); // Excavadora
    if (skill.id === 6 || skill.id === 21) createExplosion(player.x, player.y, "#ffff00", 20); // Flash / Frenesi
    if (skill.id === 7) { createExplosion(player.x, player.y, "#ff00ff", 30); player.mode = 'SHIP'; }
    if (skill.id === 8) { canDoubleJump = true; } 
    if (skill.id === 9 || skill.id === 20) { player.x += (skill.id===20 ? 400 : 300); createExplosion(player.x-100, player.y, "#00ffff", 20); } // Dash / Ninja
    if (skill.id === 10) { player.dy = 0; } // Freeze
    if (skill.id === 12) { isAntiGravity = !isAntiGravity; player.dy = 0; } // Anti-Gravity
    if (skill.id === 13) { player.y -= 200; } // Teleport Up
    if (skill.id === 14) { player.y += 200; } // Teleport Down
    if (skill.id === 15) { player.dy = (gravityInverted || isAntiGravity) ? -50 : 50; } // Ancla
    if (skill.id === 16) { map.push({x: player.x, y: player.y + 60, w: 200, h: 40, type: '#'}); } // Constructor
    if (skill.id === 17) { player.w = 100; player.h = 100; player.y -= 60; } // Mega Cubo
    if (skill.id === 18) { // Minero
        map.forEach(o => { if(o.type === '#' && o.x > player.x && o.x < player.x+200 && o.y > player.y) o.destroyed = true; });
    }
    if (skill.id === 22) { player.dy = 0; } // Levitacion
    if (skill.id === 23) { bounceMode = true; } // Rebote
    if (skill.id === 24) { doubleGemValue = true; } // Monedero
    if (skill.id === 25) { /* Chronos handled in update loop */ createExplosion(player.x, player.y, "#88f", 20); }
    if (skill.id === 26) { /* Midas handled on collision */ createExplosion(player.x, player.y, "#ffd700", 20); }
    if (skill.id === 27) { createExplosion(player.x, player.y, "#0f0", 30); } // Salto Titan effect only visual here
    if (skill.id === 28) { createExplosion(player.x, player.y, "#aaa", 15); } // Phase shift visual
}

function hasSkillEffect(effectId) {
    return (activeSkills[0].active && activeSkills[0].effect === effectId) || 
           (activeSkills[1].active && activeSkills[1].effect === effectId);
}

function parseLevel(index) {
    const level = allLevels[index];
    const rawMap = level.map;
    const rotations = level.rotations || [];
    
    mapImages = level.images || []; 
    mapTexts = level.texts || []; 
    map = []; 
    const cols = rawMap[0] ? rawMap[0].length : 60;
    mapWidthPixels = cols * TILE;
    
    const rows = rawMap.length;
    const startY = canvas.height - rows * TILE;
    winXPosition = 0;
    const calculatedFloorY = startY + (rows - 1) * TILE;

    for(let r=0; r<rows; r++) {
        for(let c=0; c<rawMap[r].length; c++) {
            const char = rawMap[r][c];
            const objX = c * TILE;
            const objY = startY + r * TILE;
            if(char !== ' ') { 
                const rotData = rotations.find(rt => rt.c === c && rt.r === r);
                const rotation = rotData ? rotData.deg : 0;
                map.push({ x: objX, y: objY, type: char, w: TILE, h: TILE, rot: rotation }); 
                if (char === 'F') winXPosition = Math.max(winXPosition, objX); 
            }
        }
    }
    return calculatedFloorY;
}

function startGame(idx) {
    currentLevelIdx = idx; 
    floorLevel = parseLevel(idx);
    
    player.x = 200; player.y = floorLevel - 50; player.dy = 0; player.mode = 'CUBE'; player.rotation = 0; player.dead = false; player.trail = []; player.w = 40; player.h = 40;
    particles = []; cameraX = 0; shake = 0; gravityInverted = false; SPEED = 11; gameState = 'PLAYING';
    levelGemsCollected = 0;
    
    activeSkills.forEach(s => { s.active = false; s.timer = 0; s.cooldownTimer = 0; s.effect = null; });
    canDoubleJump = false;
    isAntiGravity = false;
    doubleGemValue = false;
    bounceMode = false;

    playMusic(`level_${idx}`);
    updateMissionProgress('play');
    document.querySelectorAll('.menu-box, .popup-box, .top-widgets, .menu-btn-container').forEach(e => e.style.display = 'none');
    document.querySelectorAll('.modal-overlay').forEach(e => e.style.display = 'none');
    document.getElementById('progressBar').style.display = 'block';
    document.getElementById('ingamePercent').style.display = 'block';
    
