function generateTrophyRoad() {
    const list = document.getElementById('trophyList'); 
    list.innerHTML = "";
    const maxTrophies = Math.max(...allLevels.map(l => l.cups)) + 2000;
    
    for (let i = 0; i <= maxTrophies; i += 500) {
        const item = document.createElement('div');
        const unlocked = userData.totalCups >= i;
        const claimed = userData.claimedTrophies.includes(i);
        item.className = `trophy-item ${unlocked ? 'unlocked' : ''}`;
        
        let rewardAmount = 100 + (i/500)*50; 
        const levelUnlock = allLevels.find(l => l.cups === i);
        let actionBtn = "";
        if(unlocked && !claimed) actionBtn = `<button class="btn-claim" onclick="claimTrophyReward(${rewardAmount}, ${i})">RECLAMAR</button>`;
        else if (claimed) actionBtn = `<span style="color:#00ff00; font-weight:bold;">✓</span>`;
        else actionBtn = `🔒`;

        let levelInfo = "";
        if(levelUnlock) levelInfo = `<div style="font-size:11px; color:${levelUnlock.colorHex}; font-weight:bold; margin-top:3px;">🎮 Desbloquea: ${levelUnlock.name}</div>`;

        item.innerHTML = `
            <div style="display:flex; align-items:center; gap:10px;">
                <span style="font-size:24px;">${levelUnlock ? '🎮' : '💎'}</span>
                <div>
                    <div style="color: ${unlocked ? '#fff' : '#888'}">${levelUnlock ? 'NIVEL + Recompensa' : 'Recompensa'}</div>
                    <div style="font-size:14px; color:#39ff14;">+${rewardAmount} Gemas</div>
                    ${levelInfo}
                </div>
            </div>
            <div style="text-align:right; display:flex; align-items:center; gap:15px;">
                <div style="font-size:18px; font-weight:bold; color:${unlocked?'#ffd700':'#666'}">${i} 🏆</div>
                <div>${actionBtn}</div>
            </div>
        `;
        list.appendChild(item);
    }
}

function claimTrophyReward(amount, index) {
    if(userData.claimedTrophies.includes(index)) return;
    userData.gems += amount;
    userData.claimedTrophies.push(index);
    saveUserData(); updateUI(); generateTrophyRoad();
}

