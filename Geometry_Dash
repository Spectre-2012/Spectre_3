function update() {
    bgOffset += 2;
    if (gameState !== 'PLAYING') return;

    let timeScale = 1.0;
    let extraSpeed = 0;
    
    // Apply Skill Effects first to calculate timeScale
    if (hasSkillEffect(25)) timeScale = 0.5; // Chronos

    activeSkills.forEach((state, idx) => {
        if (state.active) {
            state.timer -= 16;
            if (state.timer <= 0) {
                state.active = false;
                if(state.effect === 3) { player.w = 40; player.h = 40; player.y -= 20; }
                if(state.effect === 17) { player.w = 40; player.h = 40; }
                if(state.effect === 7) { player.mode = 'CUBE'; } 
                if(state.effect === 10 || state.effect === 22) { player.dy = 0; }
                if(state.effect === 12) { isAntiGravity = false; }
                if(state.effect === 23) { bounceMode = false; }
                if(state.effect === 24) { doubleGemValue = false; }
            } else {
                if(state.effect === 2) { 
                    map.forEach(obj => {
                        if (obj.type === 'G') {
                            const dx = player.x - obj.x; const dy = player.y - obj.y; const dist = Math.sqrt(dx*dx + dy*dy);
                            if (dist < 400 && dist > 10) { obj.x += (dx/dist) * 15; obj.y += (dy/dist) * 15; }
                        }
                    });
                }
                if(state.effect === 3) { player.w = 20; player.h = 20; }
                if(state.effect === 6 || state.effect === 21) { extraSpeed = 12; createExplosion(player.x, player.y + 20, '#ffff00', 1); }
                if(state.effect === 10 || state.effect === 22) { player.dy = 0; } 
                if(state.effect === 19) { createExplosion(player.x-60, player.y, "#660066", 2); } // Clon visual
                if(state.effect === 21) { // Frenesi
                     map.forEach(obj => { if((obj.type==='#'||obj.type==='^') && Math.abs(obj.x - player.x) < 60) obj.destroyed=true; });
                }
            }
        }
        if (state.cooldownTimer > 0) state.cooldownTimer -= 16;
    });
    
    updateSkillOverlayUI();

    const percent = Math.min(Math.floor((player.x / mapWidthPixels) * 100), 100);
    document.getElementById('ingamePercent').innerText = percent + "%";

    const currentSpeed = (SPEED + extraSpeed) * timeScale;
    let grav = GRAVITY;
    if(hasSkillEffect(5)) grav = GRAVITY * 0.4;

    let effectiveGravityInverted = gravityInverted;
    if(isAntiGravity) effectiveGravityInverted = !effectiveGravityInverted;

    if (player.mode === 'CUBE') {
        player.dy += (effectiveGravityInverted ? -grav : grav) * timeScale;
        if (!player.onGround) player.rotation += (effectiveGravityInverted ? -0.15 : 0.15) * timeScale;
        else {
            player.rotation = Math.round(player.rotation / (Math.PI/2)) * (Math.PI/2);
            if(hasSkillEffect(8)) canDoubleJump = true; 
        }
    } else {
        if (input) player.dy += (effectiveGravityInverted ? -SHIP_LIFT : SHIP_LIFT) * timeScale; 
        else player.dy += (effectiveGravityInverted ? -SHIP_GRAVITY : SHIP_GRAVITY) * timeScale;
        player.dy *= 0.96; player.rotation = player.dy * 0.1;
    }

    player.y += player.dy * timeScale; 
    player.x += currentSpeed; 
    player.onGround = false;

    const prevY = player.y - (player.dy * timeScale);

    if (!effectiveGravityInverted) {
        if (player.y > floorLevel - player.h) {
            player.y = floorLevel - player.h; player.dy = 0; player.onGround = true;
        }
    }

    checkCollisions(prevY, effectiveGravityInverted);
    
    if(player.y > canvas.height + 800 || player.y < -800) die();
    if (winXPosition > 0 && player.x > winXPosition + 500) die();

    cameraX = player.x - 300; 
    if(shake > 0) shake *= 0.9; if(shake < 0.5) shake = 0;
    
    player.trail.push({x: player.x, y: player.y, r: player.rotation, a: 1.0, w: player.w, h: player.h});
    for(let i=player.trail.length-1; i>=0; i--) { player.trail[i].a -= 0.04; if(player.trail[i].a <= 0) player.trail.splice(i, 1); }
}

function updateSkillOverlayUI() {
    [0, 1].forEach(slot => {
        const id = userData.equippedSkills[slot];
        if(id !== null && id !== undefined) {
            const s = SKILLS.find(x => x.id === id);
            const overlay = document.getElementById(`skillOverlay${slot+1}`);
            const btn = document.getElementById(`skillBtn${slot+1}`);
            const state = activeSkills[slot];
            
            if (state.active) {
                btn.classList.add('active-skill'); btn.classList.remove('disabled-skill'); overlay.style.height = "0%";
            } else if (state.cooldownTimer > 0) {
                btn.classList.remove('active-skill'); btn.classList.add('disabled-skill');
                const pct = (state.cooldownTimer / s.cooldown) * 100; overlay.style.height = pct + "%";
            } else {
                btn.classList.remove('active-skill'); btn.classList.remove('disabled-skill'); overlay.style.height = "0%";
            }
        }
    });
}

function checkCollisions(prevY, effectiveGravityInverted) {
    const padding = 8; const px = player.x + padding; const py = player.y + padding; const pw = player.w - padding*2; const ph = player.h - padding*2;
    const nearby = map.filter(obj => obj.x > player.x - 150 && obj.x < player.x + 150 && !obj.destroyed);

    for (let obj of nearby) {
        if (obj.collected) continue; 
        let ox = obj.x; let oy = obj.y; let ow = obj.w; let oh = obj.h;
        let isHazard = false;
        if (obj.type === '^') { ox+=15; ow-=30; oy+=15; oh-=15; isHazard=true; } 
        if (obj.type === '_') { oy+=40; oh-=40; }
        if (obj.type === '-') { oy+=45; oh=20; } 
        if (obj.type === 'G') { ox+=15; ow-=30; oy+=15; oh-=30; } 

        if (px < ox + ow && px + pw > ox && py < oy + oh && py + ph > oy) {
            
            if (isHazard && (hasSkillEffect(0) || hasSkillEffect(11))) continue; // Inmunidad/Fantasma
            
            // Excavadora / Frenesi / Mega Cubo / Phase Shift
            if ((obj.type === '#' || obj.type === '-') && (hasSkillEffect(4) || hasSkillEffect(21) || hasSkillEffect(17))) {
                obj.destroyed = true; createExplosion(obj.x + TILE/2, obj.y + TILE/2, '#888', 10); shake = 5; continue;
            }
            // Phase Shift logic (just ignore collisions with walls)
            if ((obj.type === '#' || obj.type === '-') && hasSkillEffect(28)) {
                continue; 
            }

            if (obj.type === '^') { die(); return; }
            if (obj.type === 'F') { win(); return; }
            if (obj.type === 'G') { 
                obj.collected = true; 
                let val = doubleGemValue ? 2 : 1;
                if(hasSkillEffect(26)) val = 5; // Midas
                levelGemsCollected += val; 
                createExplosion(obj.x + 32, obj.y + 32, "#39ff14", 10); continue; 
            }
            if (obj.type === 'S') { player.mode = 'SHIP'; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#f0f', 15); continue; }
            if (obj.type === 'C') { player.mode = 'CUBE'; player.w=40; player.h=40; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#0f0', 15); player.y = Math.round(player.y/10)*10; gravityInverted = false; continue; }
            if (obj.type === 'O') { if (inputPressed) { player.dy = (effectiveGravityInverted ? -JUMP_FORCE : JUMP_FORCE) * 1.3; inputPressed = false; createExplosion(obj.x + TILE/2, obj.y + TILE/2, '#FF0', 20); shake = 8; } continue; }
            if (obj.type === '_') { player.dy = (effectiveGravityInverted ? 1 : -1) * Math.abs(JUMP_FORCE * 1.5); player.onGround = false; createExplosion(obj.x + TILE/2, obj.y + TILE/2, '#FF0', 20); shake = 5; continue; }
            if (obj.type === '>') { SPEED = 18; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#0FF', 10); continue; }
            if (obj.type === '<') { SPEED = 8; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#008888', 10); continue; }
            if (obj.type === 'M') { player.w = 20; player.h = 20; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#aa00aa', 10); continue; }
            if (obj.type === 'B') { gravityInverted = !gravityInverted; player.dy = 0; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#00F', 20); continue; }

            if (obj.type === '#' || obj.type === '-') {
                if(bounceMode) { player.dy = -player.dy * 1.2; continue; } // Rebote

                if (!effectiveGravityInverted) {
                    if (prevY + player.h <= oy + 25) { player.y = oy - player.h + padding; player.dy = 0; player.onGround = true; } 
                    else if (py > oy + oh - 20) { player.y = oy + oh - padding; player.dy = 0; if(player.mode === 'CUBE') die(); } 
                    else { die(); }
                } else {
                    if (prevY >= oy + oh - 25) { player.y = oy + oh - padding; player.dy = 0; player.onGround = true; } 
                    else if (py + ph < oy + 20) { player.y = oy - player.h + padding; player.dy = 0; if(player.mode === 'CUBE') die(); } 
                    else { die(); }
                }
            }
        }
    }
}

function die() {
    if(devSettings.godMode || hasSkillEffect(0)) return; 
    if(player.dead) return;
    player.dead = true; gameState = 'DEAD'; shake = 30;
    
    userData.gems += levelGemsCollected;
    document.getElementById('deathGems').innerText = levelGemsCollected;

    let percent = Math.floor((player.x / mapWidthPixels) * 100); if(percent > 100) percent = 99;
    document.getElementById('percentText').innerText = percent + "%";
    
    if (!userData.levels[currentLevelIdx] || percent > userData.levels[currentLevelIdx].best) {
        if (!userData.levels[currentLevelIdx]) userData.levels[currentLevelIdx] = {};
        userData.levels[currentLevelIdx].best = percent; saveUserData();
    }
    
    const color = allLevels[currentLevelIdx].colorHex;
    createExplosion(player.x + 20, player.y + 20, color, 80);
    setTimeout(() => { document.getElementById('deathMenu').style.display = 'block'; }, 800);
}

function win() {
    gameState = 'WIN'; createExplosion(player.x, player.y, '#fff', 150);
    if (!userData.levels[currentLevelIdx]) userData.levels[currentLevelIdx] = {};
    userData.levels[currentLevelIdx].best = 100;
    const earnedCups = 100; const rewardGems = allLevels[currentLevelIdx].diamonds + levelGemsCollected;
    userData.totalCups += earnedCups; userData.gems += rewardGems;
    updateMissionProgress('win'); 
    document.getElementById('cupReward').innerText = earnedCups; document.getElementById('gemReward').innerText = allLevels[currentLevelIdx].diamonds; document.getElementById('winGems').innerText = levelGemsCollected;
    saveUserData(); updateUI(); document.getElementById('winMenu').style.display = 'block';
}

function createExplosion(x, y, color, count) {
    for(let i=0; i<count; i++) { particles.push({ x: x, y: y, vx: (Math.random()-0.5)*20, vy: (Math.random()-0.5)*20, life: 1.0, color: color, size: Math.random()*12 }); }
}

function draw() {
    ctx.save(); if(shake > 0) ctx.translate(Math.random()*shake - shake/2, Math.random()*shake - shake/2);
    
    let hue = 220; if(gameState === 'PLAYING') hue += Math.sin(Date.now() * 0.001) * 20; 
    const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, `hsl(${hue}, 60%, 15%)`); grad.addColorStop(1, `hsl(${hue}, 60%, 5%)`);
    ctx.fillStyle = grad; ctx.fillRect(-shake, -shake, canvas.width+shake*2, canvas.height+shake*2);
    
    if (gameState === 'MENU') { ctx.restore(); return; }
    
    let hex = allLevels[currentLevelIdx].colorHex;
    ctx.fillStyle = hex; ctx.globalAlpha = 0.2; ctx.fillRect(0, floorLevel, canvas.width, canvas.height - floorLevel); ctx.globalAlpha = 1; ctx.fillRect(0, floorLevel, canvas.width, 5);

    ctx.translate(-cameraX, 0);

    // IMAGES
    mapImages.forEach(img => {
        if(img.x > cameraX - img.w && img.x < cameraX + canvas.width) {
            const imageEl = new Image(); imageEl.src = img.src; ctx.drawImage(imageEl, img.x, img.y, img.w, img.h);
        }
    });

    // TEXTS
    mapTexts.forEach(txt => {
        if(txt.x > cameraX - 1000 && txt.x < cameraX + canvas.width) {
            ctx.save();
            ctx.fillStyle = txt.color;
            ctx.font = `${txt.size}px ${txt.font}`;
            ctx.fillText(txt.text, txt.x, txt.y);
            ctx.restore();
        }
    });

    const visibleMap = map.filter(o => o.x > cameraX - 100 && o.x < cameraX + canvas.width + 100 && !o.collected && !o.destroyed);

    for (let obj of visibleMap) {
        ctx.save();
        if (obj.rot) { ctx.translate(obj.x + obj.w/2, obj.y + obj.h/2); ctx.rotate(obj.rot * Math.PI / 180); ctx.translate(-(obj.x + obj.w/2), -(obj.y + obj.h/2)); }

        if (obj.type === '#') { ctx.fillStyle = 'black'; ctx.fillRect(obj.x, obj.y, TILE, TILE); ctx.strokeStyle = hex; ctx.lineWidth = 3; ctx.strokeRect(obj.x, obj.y, TILE, TILE); ctx.globalAlpha = 0.4; ctx.fillStyle = hex; ctx.fillRect(obj.x+15, obj.y+15, TILE-30, TILE-30); ctx.globalAlpha = 1; } 
        else if (obj.type === '-') { ctx.fillStyle = 'black'; ctx.fillRect(obj.x, obj.y + 45, TILE, 20); ctx.strokeStyle = hex; ctx.lineWidth = 3; ctx.strokeRect(obj.x, obj.y + 45, TILE, 20); }
        else if (obj.type === '^') { ctx.fillStyle = 'black'; ctx.strokeStyle = 'white'; ctx.lineWidth = 3; ctx.beginPath(); ctx.moveTo(obj.x, obj.y + TILE); ctx.lineTo(obj.x + TILE/2, obj.y); ctx.lineTo(obj.x + TILE, obj.y + TILE); ctx.fill(); ctx.stroke(); ctx.fillStyle = '#f00'; ctx.beginPath(); ctx.moveTo(obj.x+20, obj.y+50); ctx.lineTo(obj.x+32, obj.y+30); ctx.lineTo(obj.x+45, obj.y+50); ctx.fill(); } 
        else if (obj.type === 'G') { const gx = obj.x + TILE/2; const gy = obj.y + TILE/2; const size = 18; ctx.translate(gx, gy); ctx.rotate(Math.sin(Date.now()/500)*0.2); ctx.shadowBlur = 10; ctx.shadowColor = '#00ffff'; ctx.fillStyle = '#00ffff'; ctx.beginPath(); ctx.moveTo(0, -size); ctx.lineTo(size, 0); ctx.lineTo(0, size); ctx.lineTo(-size, 0); ctx.fill(); ctx.lineWidth = 2; ctx.strokeStyle = 'white'; ctx.stroke(); ctx.shadowBlur = 0; }
        else if (obj.type === '_') { ctx.fillStyle = '#ff0'; ctx.fillRect(obj.x+5, obj.y+50, 55, 15); ctx.strokeStyle = 'white'; ctx.strokeRect(obj.x+5, obj.y+50, 55, 15); }
        else if (obj.type === 'O') { ctx.fillStyle = '#ff0'; ctx.beginPath(); ctx.arc(obj.x+32, obj.y+32, 15, 0, Math.PI*2); ctx.fill(); ctx.lineWidth=3; ctx.strokeStyle='white'; ctx.stroke(); }
        else if (obj.type === '>') { ctx.fillStyle = '#0FF'; ctx.beginPath(); ctx.moveTo(obj.x+10, obj.y+10); ctx.lineTo(obj.x+50, obj.y+32); ctx.lineTo(obj.x+10, obj.y+54); ctx.fill(); ctx.lineWidth=3; ctx.strokeStyle='white'; ctx.stroke(); }
        else if (obj.type === '<') { ctx.fillStyle = '#008888'; ctx.beginPath(); ctx.moveTo(obj.x+50, obj.y+10); ctx.lineTo(obj.x+10, obj.y+32); ctx.lineTo(obj.x+50, obj.y+54); ctx.fill(); ctx.lineWidth=3; ctx.strokeStyle='white'; ctx.stroke(); }
        else if (obj.type === 'M') { player.w = 20; player.h = 20; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#aa00aa', 10); continue; }
        else if (obj.type === 'B') { gravityInverted = !gravityInverted; player.dy = 0; createExplosion(obj.x+TILE/2, obj.y+TILE/2, '#00F', 20); continue; }
        else if (obj.type === 'S') { ctx.font='40px Arial'; ctx.fillText('✈️', obj.x+5, obj.y+45); }
        else if (obj.type === 'C') { ctx.font='40px Arial'; ctx.fillText('🟩', obj.x+5, obj.y+45); }
        else if (obj.type === 'M') { ctx.font='30px Arial'; ctx.fillText('🐭', obj.x+10, obj.y+45); }
        else if (obj.type === 'F') { ctx.font='40px Arial'; ctx.fillText('🏁', obj.x+5, obj.y+45); }
        ctx.restore();
    }

    const skinData = SKINS.find(s => s.id === userData.currentSkin);
    const skinColor = skinData ? skinData.color : hex;
    const trailData = TRAILS.find(tr => tr.id === userData.currentTrail);
    
    player.trail.forEach(t => {
        ctx.save(); ctx.translate(t.x + t.w/2, t.y + t.h/2); ctx.rotate(t.r); ctx.globalAlpha = t.a * 0.4;
        if (trailData && trailData.type === 'sparkle') { ctx.fillStyle = trailData.color; ctx.beginPath(); ctx.arc((Math.random()-0.5)*20, (Math.random()-0.5)*20, Math.random()*3+2, 0, Math.PI*2); ctx.fill(); } 
        else if (trailData && trailData.type === 'rainbow') { ctx.fillStyle = `hsl(${(Date.now()/5 + t.x) % 360}, 100%, 50%)`; ctx.fillRect(-t.w/2, -t.h/2, t.w, t.h); } 
        else { ctx.fillStyle = skinColor === 'rainbow' ? `hsl(${Date.now()/10 % 360}, 100%, 50%)` : skinColor; ctx.fillRect(-t.w/2, -t.h/2, t.w, t.h); }
        ctx.restore();
    });

    if (!player.dead) {
        ctx.save(); ctx.translate(player.x + player.w/2, player.y + player.h/2); ctx.rotate(player.rotation);
        
        if (hasSkillEffect(0)) { // Shield
            ctx.shadowBlur = 20; ctx.shadowColor = "#00ffcc"; ctx.strokeStyle = "#00ffcc"; ctx.lineWidth = 4; ctx.beginPath(); ctx.arc(0,0, 35, 0, Math.PI*2); ctx.stroke(); ctx.shadowBlur = 0;
        }

        let playerColor = skinColor === 'rainbow' ? `hsl(${Date.now()/10 % 360}, 100%, 50%)` : skinColor;
        if(player.mode !== 'CUBE') playerColor = '#F0F';
        
        ctx.fillStyle = playerColor; ctx.fillRect(-player.w/2, -player.h/2, player.w, player.h);
        ctx.strokeStyle = 'white'; ctx.lineWidth = 3; ctx.strokeRect(-player.w/2, -player.h/2, player.w, player.h);
        ctx.fillStyle = 'black'; let eyeSize = player.w / 4; let eyeOffset = player.w / 4; ctx.fillRect(eyeOffset/2, (gravityInverted || isAntiGravity) ? 0 : -eyeOffset, eyeSize, eyeSize);
        ctx.restore();
    }

    particles.forEach((p, i) => {
        p.x += p.vx; p.y += p.vy; p.life -= 0.02;
        ctx.globalAlpha = p.life; ctx.fillStyle = p.color; ctx.fillRect(p.x, p.y, p.size, p.size);
        ctx.globalAlpha = 1; if(p.life <= 0) particles.splice(i, 1);
    });

    ctx.restore();
    const percent = Math.min((player.x / mapWidthPixels)*100, 100);
    document.getElementById('progressFill').style.width = percent + "%";
}

// ==================== EDITOR ====================
let editorCanvas = document.getElementById('editorCanvas');
let eCtx = editorCanvas.getContext('2d');
let editorMap = []; let editorImages = []; let editorTexts = [];
let editorTool = 'remove'; let editorActive = false; let editingIndex = -1; let isMouseDown = false;
let editorMusicBlob = null; let editorCols = 60; const EDITOR_ROWS = 10; let EDITOR_TILE_SIZE = 20; let editorScrollX = 0; let editorRotation = 0;

function openLevelCreatorMenu() { toggleModal('devSettingsModal'); toggleModal('levelCreatorMenu'); }

function renderLevelCreatorList() {
    const list = document.getElementById('editLevelList'); list.innerHTML = "";
    allLevels.forEach((level, idx) => {
        const div = document.createElement('div'); div.className = 'level-edit-item';
        div.innerHTML = `<span style="color:${level.colorHex}; font-weight:bold;">${level.name}</span><div style="display:flex; gap:8px;"><button style="background:#ffd700; color:black; border:none; padding:5px 12px; border-radius:5px; font-weight:bold; cursor:pointer; font-size:11px;" onclick="editLevel(${idx})">✏️ EDITAR</button><button class="btn-delete-level" onclick="deleteLevel(${idx})">🗑️ ELIMINAR</button></div>`;
        list.appendChild(div);
    });
}

function deleteLevel(idx) { if(confirm(`⚠️ ¿ELIMINAR "${allLevels[idx].name}"?`)) { allLevels.splice(idx, 1); saveLevels(); renderLevelCreatorList(); generateLevelsGrid(); determineActiveLevel(); } }

function editLevel(idx) {
    editingIndex = idx; const level = allLevels[idx]; editorMap = []; editorImages = level.images || []; editorTexts = level.texts || [];
    const rawMap = level.map; const rots = level.rotations || [];
    editorCols = rawMap[0] ? rawMap[0].length : 60;
    for(let r = 0; r < rawMap.length && r < EDITOR_ROWS; r++) {
        const editorR = EDITOR_ROWS - rawMap.length + r;
        if(editorR >= 0) {
            for(let c = 0; c < rawMap[r].length && c < editorCols; c++) {
                const char = rawMap[r][c];
                if(char !== ' ') { const rt = rots.find(x => x.c === c && x.r === editorR); editorMap.push({ c: c, r: editorR, type: char, rot: rt ? rt.deg : 0 }); }
            }
        }
    }
    editorMusicBlob = level.musicBlob || null; initEditor(level.name, level.colorHex);
}

function startNewLevel() {
    editingIndex = -1; editorMap = []; editorImages = []; editorTexts = []; editorCols = 60;
    for(let c = 0; c < editorCols; c++) { editorMap.push({ c: c, r: EDITOR_ROWS - 1, type: '#' }); }
    editorMap.push({ c: editorCols - 3, r: EDITOR_ROWS - 2, type: 'F' });
    initEditor("NUEVO NIVEL", "#00ff00");
}

function initEditor(name, color) {
    toggleModal('levelCreatorMenu'); document.getElementById('editorUI').style.display = 'block';
    document.getElementById('editorLevelName').innerText = name; document.getElementById('levelColorPicker').value = color; document.getElementById('levelWidthInput').value = editorCols;
    editorScrollX = 0; editorRotation = 0; updateRotBtn(); editorActive = true; resizeEditor(); requestAnimationFrame(editorLoop);
}

function toggleEditorRotation() { editorRotation = (editorRotation + 90) % 360; updateRotBtn(); }
function updateRotBtn() { document.getElementById('rotDisplay').innerText = editorRotation + "°"; }

function updateLevelWidth() {
    const newWidth = parseInt(document.getElementById('levelWidthInput').value); if(newWidth < 20) return;
    if(newWidth > editorCols) { for(let c = editorCols; c < newWidth; c++) { editorMap.push({ c: c, r: EDITOR_ROWS - 1, type: '#' }); } } else { editorMap = editorMap.filter(o => o.c < newWidth); }
    editorCols = newWidth;
}

function handleEditorImageUpload(input) {
    const file = input.files[0]; if(!file) return;
    const reader = new FileReader(); reader.onload = function(e) { editorImages.push({ x: 100 + editorScrollX, y: 100, w: 100, h: 100, src: e.target.result }); alert("Imagen insertada."); }; reader.readAsDataURL(file);
}

function exitEditor() { if(confirm("¿Salir sin guardar?")) { editorActive = false; document.getElementById('editorUI').style.display = 'none'; } }

function saveLevelPrompt() { const name = prompt("📝 Nombre del nivel:", document.getElementById('editorLevelName').innerText); if(!name) return; saveLevel(name, document.getElementById('levelColorPicker').value); }

function saveLevel(name, color) {
    let newMap = []; let rotArray = [];
    for(let r = 0; r < EDITOR_ROWS; r++) {
        let rowStr = "";
        for(let c = 0; c < editorCols; c++) {
            const obj = editorMap.find(o => o.c === c && o.r === r);
            if (obj) { rowStr += obj.type; if(obj.rot !== 0) rotArray.push({c: c, r: r, deg: obj.rot}); } else { rowStr += " "; }
        }
        newMap.push(rowStr);
    }
    const maxCups = allLevels.length > 0 ? Math.max(...allLevels.map(l => l.cups)) : 0;
    const levelData = { name: name, diff: "Custom", colorHex: color, cups: maxCups + 1000, diamonds: 500, map: newMap, rotations: rotArray, images: editorImages, texts: editorTexts, musicBlob: editorMusicBlob };
    if(editingIndex === -1) allLevels.push(levelData); else allLevels[editingIndex] = levelData;
    saveLevels(); editorActive = false; document.getElementById('editorUI').style.display = 'none'; generateLevelsGrid(); determineActiveLevel();
}

function selectTool(t) { editorTool = t; document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('selected')); event.currentTarget.classList.add('selected'); }

const editorVp = document.getElementById('editorViewport');

function getEditorCoords(e) {
    const rect = editorCanvas.getBoundingClientRect();
    const mx = e.clientX - rect.left + editorScrollX; 
    return { x: mx, y: e.clientY - rect.top, c: Math.floor(mx / EDITOR_TILE_SIZE), r: Math.floor((e.clientY - rect.top) / EDITOR_TILE_SIZE) };
}

let isDraggingImage = false; let draggedImageIdx = -1; let dragOffsetX = 0; let dragOffsetY = 0;
let isDraggingText = false; let draggedTextIdx = -1;

editorCanvas.addEventListener('wheel', (e) => {
    if(!editorActive) return; e.preventDefault();
    editorScrollX += e.deltaY; if(editorScrollX < 0) editorScrollX = 0;
}, { passive: false });

editorVp.addEventListener('mousedown', (e) => {
    if(!editorActive) return;
    const coords = getEditorCoords(e);
    const mx = coords.x; const my = coords.y;

    // Check Texts first (Top Layer)
    for(let i = editorTexts.length - 1; i >= 0; i--) {
        const t = editorTexts[i];
        eCtx.font = `${t.size}px ${t.font}`;
        const w = eCtx.measureText(t.text).width;
        const h = parseInt(t.size);
        
        // Better Text Collision
        if(mx >= t.x && mx <= t.x + w && my >= t.y - h && my <= t.y + h/2) {
            if(editorTool === 'remove') { editorTexts.splice(i, 1); return; }
            isDraggingText = true; draggedTextIdx = i; dragOffsetX = mx - t.x; dragOffsetY = my - t.y; return;
        }
    }

    // Check Images
    for(let i = editorImages.length - 1; i >= 0; i--) {
        const img = editorImages[i];
        if(mx >= img.x && mx <= img.x + img.w && my >= img.y && my <= img.y + img.h) {
             if(editorTool === 'remove') { editorImages.splice(i, 1); return; }
            isDraggingImage = true; draggedImageIdx = i; dragOffsetX = mx - img.x; dragOffsetY = my - img.y; return;
        }
    }

    if(editorTool === 'TEXT') {
        const txt = prompt("Introduce el texto:");
        if(txt) {
            const size = prompt("Tamaño (px):", "40");
            const color = prompt("Color (Hex o nombre):", "white");
            const font = prompt("Fuente (Arial, Montserrat, 'Press Start 2P', 'Dancing Script'):", "Montserrat");
            editorTexts.push({ x: mx, y: my, text: txt, size: size || 40, color: color || 'white', font: font || 'Montserrat' });
        }
        return;
    }

    isMouseDown = true; handleEditorClick(e);
});

editorVp.addEventListener('mousemove', (e) => {
    if(!editorActive) return;
    const coords = getEditorCoords(e);
    if(isDraggingImage && draggedImageIdx !== -1) { editorImages[draggedImageIdx].x = coords.x - dragOffsetX; editorImages[draggedImageIdx].y = coords.y - dragOffsetY; return; }
    if(isDraggingText && draggedTextIdx !== -1) { editorTexts[draggedTextIdx].x = coords.x - dragOffsetX; editorTexts[draggedTextIdx].y = coords.y - dragOffsetY; return; }
    if(isMouseDown) handleEditorClick(e);
});

editorVp.addEventListener('mouseup', () => { isMouseDown = false; isDraggingImage = false; draggedImageIdx = -1; isDraggingText = false; draggedTextIdx = -1; });
editorVp.addEventListener('mouseleave', () => { isMouseDown = false; isDraggingImage = false; draggedImageIdx = -1; });

function handleEditorClick(e) {
    if(!editorActive) return;
    const {c, r} = getEditorCoords(e);
    if(c < 0 || c >= editorCols || r < 0 || r >= EDITOR_ROWS) return;
    const existingIdx = editorMap.findIndex(o => o.c === c && o.r === r);
    if(editorTool === 'remove') { if(existingIdx !== -1) editorMap.splice(existingIdx, 1); } 
    else { if(existingIdx !== -1) editorMap.splice(existingIdx, 1); editorMap.push({ c: c, r: r, type: editorTool, rot: editorRotation }); }
}

function resizeEditor() {
    const vp = document.getElementById('editorViewport');
    if(vp && editorCanvas) { editorCanvas.width = vp.clientWidth; editorCanvas.height = vp.clientHeight; EDITOR_TILE_SIZE = (editorCanvas.height - 20) / EDITOR_ROWS; }
}
window.addEventListener('resize', resizeEditor);

function editorLoop() {
    if(!editorActive) return;
    eCtx.fillStyle = '#111'; eCtx.fillRect(0, 0, editorCanvas.width, editorCanvas.height);
    const hex = document.getElementById('levelColorPicker').value;

    eCtx.save(); eCtx.translate(-editorScrollX, 0);
    const startCol = Math.floor(editorScrollX / EDITOR_TILE_SIZE); const endCol = startCol + Math.ceil(editorCanvas.width / EDITOR_TILE_SIZE) + 1;

    // Images
    editorImages.forEach((img, i) => {
       if (img.x + img.w < editorScrollX || img.x > editorScrollX + editorCanvas.width) return;
       const imageEl = new Image(); imageEl.src = img.src;
       if(imageEl.complete && imageEl.naturalWidth !== 0) eCtx.drawImage(imageEl, img.x, img.y, img.w, img.h);
       else { eCtx.fillStyle = 'rgba(255,255,255,0.1)'; eCtx.fillRect(img.x, img.y, img.w, img.h); eCtx.fillStyle = '#fff'; eCtx.fillText("IMG", img.x+5, img.y+15); }
       eCtx.strokeStyle = (i === draggedImageIdx) ? '#ffff00' : '#00ffff'; eCtx.lineWidth = (i === draggedImageIdx) ? 2 : 1; eCtx.strokeRect(img.x, img.y, img.w, img.h);
    });

    // Texts
    editorTexts.forEach((txt, i) => {
        if (txt.x < editorScrollX || txt.x > editorScrollX + editorCanvas.width) return;
        eCtx.save(); eCtx.fillStyle = txt.color; eCtx.font = `${txt.size}px ${txt.font}`; eCtx.fillText(txt.text, txt.x, txt.y); 
        const w = eCtx.measureText(txt.text).width;
        eCtx.restore();
        
        eCtx.strokeStyle = (i === draggedTextIdx) ? '#ffff00' : 'rgba(255,255,255,0.3)'; eCtx.lineWidth = 1; 
        eCtx.strokeRect(txt.x, txt.y - parseInt(txt.size), w, parseInt(txt.size) + 5);
    });

    // Grid
    eCtx.strokeStyle = '#222'; eCtx.lineWidth = 1;
    for(let i = startCol; i <= endCol && i <= editorCols; i++) { eCtx.beginPath(); eCtx.moveTo(i * EDITOR_TILE_SIZE, 0); eCtx.lineTo(i * EDITOR_TILE_SIZE, EDITOR_ROWS * EDITOR_TILE_SIZE); eCtx.stroke(); }
    for(let i = 0; i <= EDITOR_ROWS; i++) { eCtx.beginPath(); eCtx.moveTo(startCol * EDITOR_TILE_SIZE, i * EDITOR_TILE_SIZE); eCtx.lineTo(endCol * EDITOR_TILE_SIZE, i * EDITOR_TILE_SIZE); eCtx.stroke(); }
    
    // Objects
    for(let obj of editorMap) {
        if (obj.c < startCol || obj.c > endCol) continue;
        const x = obj.c * EDITOR_TILE_SIZE; const y = obj.r * EDITOR_TILE_SIZE; const ts = EDITOR_TILE_SIZE;
        eCtx.save(); if (obj.rot) { eCtx.translate(x + ts/2, y + ts/2); eCtx.rotate(obj.rot * Math.PI / 180); eCtx.translate(-(x + ts/2), -(y + ts/2)); }
        if(obj.type === '#') { eCtx.fillStyle = 'black'; eCtx.fillRect(x, y, ts, ts); eCtx.strokeStyle = hex; eCtx.lineWidth = 2; eCtx.strokeRect(x, y, ts, ts); } 
        else if(obj.type === '-') { eCtx.fillStyle = '#ccc'; eCtx.fillRect(x, y+ts/2, ts, ts/2); }
        else if(obj.type === 'G') { eCtx.fillStyle = '#39ff14'; eCtx.beginPath(); eCtx.moveTo(x + ts/2, y); eCtx.lineTo(x + ts, y + ts/2); eCtx.lineTo(x + ts/2, y + ts); eCtx.lineTo(x, y + ts/2); eCtx.fill(); }
        else if(obj.type === '^') { eCtx.fillStyle = '#f00'; eCtx.beginPath(); eCtx.moveTo(x, y + ts); eCtx.lineTo(x + ts/2, y); eCtx.lineTo(x + ts, y + ts); eCtx.fill(); }
        else if(obj.type === 'O') { eCtx.fillStyle = '#ffff00'; eCtx.beginPath(); eCtx.arc(x + ts/2, y + ts/2, ts*0.35, 0, Math.PI*2); eCtx.fill(); eCtx.strokeStyle = 'white'; eCtx.lineWidth = 2; eCtx.stroke(); }
        else if(obj.type === '_') { eCtx.fillStyle = '#ffff00'; eCtx.beginPath(); eCtx.arc(x + ts/2, y + ts, ts*0.5, Math.PI, 0); eCtx.fill(); }
        else if(obj.type === 'S') { eCtx.fillStyle = '#ff00ff'; eCtx.globalAlpha = 0.3; eCtx.fillRect(x,y,ts,ts); eCtx.globalAlpha = 1; eCtx.font = `${ts*0.8}px Arial`; eCtx.textAlign = 'center'; eCtx.textBaseline = 'middle'; eCtx.fillStyle = 'white'; eCtx.fillText('✈️', x + ts/2, y + ts/2); }
        else if(obj.type === 'C') { eCtx.fillStyle = '#00ff00'; eCtx.globalAlpha = 0.3; eCtx.fillRect(x,y,ts,ts); eCtx.globalAlpha = 1; eCtx.font = `${ts*0.8}px Arial`; eCtx.textAlign = 'center'; eCtx.textBaseline = 'middle'; eCtx.fillStyle = 'white'; eCtx.fillText('🟩', x + ts/2, y + ts/2); }
        else if(obj.type === 'F') { eCtx.font = `${ts*0.9}px Arial`; eCtx.textAlign = 'center'; eCtx.textBaseline = 'middle'; eCtx.fillStyle = 'white'; eCtx.fillText('🏁', x + ts/2, y + ts/2); }
        else if(obj.type === '>') { eCtx.fillStyle = '#00ffff'; eCtx.beginPath(); eCtx.moveTo(x + ts*0.2, y + ts*0.2); eCtx.lineTo(x + ts*0.8, y + ts/2); eCtx.lineTo(x + ts*0.2, y + ts*0.8); eCtx.fill(); }
        else if(obj.type === '<') { eCtx.fillStyle = '#008888'; eCtx.beginPath(); eCtx.moveTo(x + ts*0.8, y + ts*0.2); eCtx.lineTo(x + ts*0.2, y + ts/2); eCtx.lineTo(x + ts*0.8, y + ts*0.8); eCtx.fill(); }
        else if(obj.type === 'B') { eCtx.fillStyle = '#0000ff'; eCtx.beginPath(); eCtx.arc(x + ts/2, y + ts, ts*0.5, Math.PI, 0); eCtx.fill(); eCtx.fillStyle = 'white'; eCtx.font = `${ts*0.4}px Arial`; eCtx.textAlign = 'center'; eCtx.fillText('G', x+ts/2, y+ts*0.8); }
        eCtx.restore();
    }
    
    eCtx.restore();
    requestAnimationFrame(editorLoop);
}

// ==================== FUNCIONES DEVELOPER ====================

function checkDevAuth() {
    // Esta función permite el acceso developer desde dentro del juego si ya estás logueado
    const user = document.getElementById('devUser').value.trim();
    const pass = document.getElementById('devPass').value.trim();
    let success = false;

    if (user === "Leo" && pass === "4102") success = true;
    else if (user === "Hugo" && pass === "0227") success = true;
    else if (user === "Pedro" && pass === "1620") success = true;

    if (success) {
        isDevMode = true;
        document.getElementById('devModal').style.display = 'none';
        document.getElementById('devSettingsWidget').style.display = 'flex';
        document.getElementById('devExitWidget').style.display = 'flex';
        generateLevelsGrid(); 
        alert(`✅ ACCESO CONCEDIDO: Bienvenido ${user}`);
    } else {
        alert("❌ CREDENCIALES INCORRECTAS");
    }
}

function toggleDevSetting(setting) {
    if (!isDevMode) return;
    devSettings[setting] = !devSettings[setting];
    
    const btnId = setting === 'godMode' ? 'toggleGod' : 'toggleInfGems';
    const btn = document.getElementById(btnId);
    
    if (devSettings[setting]) {
        btn.classList.add('active');
    } else {
        btn.classList.remove('active');
    }
    updateUI(); 
}

function devAddCups() {
    if (!isDevMode) return;
    userData.totalCups += 500;
    saveUserData();
    updateUI();
    if(document.getElementById('trophyRoadModal').style.display === 'flex') {
        generateTrophyRoad();
    }
}

function exitDevMode() {
    isDevMode = false;
    devSettings.godMode = false;
    devSettings.infGems = false;
    
    document.getElementById('toggleGod').classList.remove('active');
    document.getElementById('toggleInfGems').classList.remove('active');
    
    document.getElementById('devSettingsWidget').style.display = 'none';
    document.getElementById('devExitWidget').style.display = 'none';
    document.getElementById('devSettingsModal').style.display = 'none';
    
    generateLevelsGrid(); 
    updateUI();
    alert("🔒 Has salido del modo Developer");
}

function loop() { update(); draw(); requestAnimationFrame(loop); }
